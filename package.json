{
  "name": "rxjs-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "RxJS のストリームが「いつ・どの順で・並行に」流れるかをアニメーションで見せる学習用ビジュアライザ",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
